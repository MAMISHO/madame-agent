# Container Environment Configuration
# Copy this file to .env.container and fill in the values

# Application port (OpenCode CLI server)
PORT=4098

# Node environment
NODE_ENV=development

# OpenCode API configuration
# Obtain your API key from https://opencode.ai/settings
OPENCODE_API_KEY=

# OpenCode server URL (for container networking)
OPENCODE_URL=http://localhost:4098