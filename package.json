{
  "name": "madame-agent-monorepo",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "apps/opencode-plugin"
  ],
  "scripts": {
    "backend:build": "npm run build -w apps/backend",
    "backend:start": "npm run start -w apps/backend",
    "backend:dev": "npm run start:dev -w apps/backend",
    "frontend:build": "npm run build -w apps/frontend",
    "frontend:dev": "npm run start -w apps/frontend",
    "plugin:build": "npm run build -w apps/opencode-plugin",
    "package": "npm run frontend:build && npm run backend:build && npm run package -w apps/opencode-plugin"
  },
  "devDependencies": {
    "@nx/eslint": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/vitest": "23.0.1",
    "eslint": "^9.8.0",
    "jest": "~30.3.0",
    "nx": "23.0.1",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "global-agent": "^4.1.3"
  }
}
